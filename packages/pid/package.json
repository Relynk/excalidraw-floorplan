{
  "name": "@excalidraw/pid",
  "version": "0.18.0",
  "type": "module",
  "types": "./dist/types/pid/src/index.d.ts",
  "main": "./dist/prod/index.js",
  "module": "./dist/prod/index.js",
  "exports": {
    ".": {
      "types": "./dist/types/pid/src/index.d.ts",
      "development": "./dist/dev/index.js",
      "production": "./dist/prod/index.js",
      "default": "./dist/prod/index.js"
    },
    "./*": {
      "types": "./dist/types/pid/src/*.d.ts",
      "development": "./dist/dev/index.js",
      "production": "./dist/prod/index.js",
      "default": "./dist/prod/index.js"
    }
  },
  "files": [
    "dist/*"
  ],
  "description": "P&ID symbol library, typed ports, and state engine for Excalidraw floorplan",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "keywords": [
    "excalidraw",
    "pid",
    "p&id",
    "process-diagram"
  ],
  "scripts": {
    "gen:types": "rimraf types && tsc",
    "build:esm": "rimraf dist && node ../../scripts/buildBase.js && yarn gen:types"
  },
  "dependencies": {
    "@excalidraw/common": "0.18.0",
    "@excalidraw/element": "0.18.0",
    "@excalidraw/math": "0.18.0"
  }
}
